{
    "outputDirectory": "client/build",
    "rewrites": [
        {
            "source": "/socket.io/(.*)",
            "destination": "https://devsphere-uh2m.onrender.com/socket.io/$1"
        },
        {
            "source": "/api/ai/agent",
            "destination": "/api/ai/agent.js"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Cross-Origin-Opener-Policy",
                    "value": "unsafe-none"
                },
                {
                    "key": "Cross-Origin-Embedder-Policy",
                    "value": "unsafe-none"
                }
            ]
        }
    ]
}